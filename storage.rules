rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Node-specific storage
    match /nodes/{nodeId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == nodeId;
    }
    // Shared storage via secret
    match /shared/{secretHash}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
